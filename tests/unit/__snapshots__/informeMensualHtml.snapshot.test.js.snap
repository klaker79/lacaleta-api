        color: var(--muted);
        font-weight: 400;
        font-size: 12px;
    }
    /* Mermas KPI */
    .mermas-kpi {
        background: #fef2f2;
        border-left: 4px solid var(--bad);
        padding: 14px 18px;
        border-radius: 6px;

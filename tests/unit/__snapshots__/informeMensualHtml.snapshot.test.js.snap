        table, .reco, .resumen, .alerta, .kpi-card { page-break-inside: avoid; }
    }
</style>
</head>
<body>
<div class="container">
    <div class="print-bar">
        <button class="btn-print" onclick="window.print()">🖨️ Print / Save as PDF</button>
    </div>
    <div class="report">
        <header class="cover">
            <h1>Monthly Executive Report</h1>
            <div class="subtitle">Period: 2026-04</div>
            <div class="restaurante">KL Restaurant</div>
        </header>

        <section>
            <h2>📊 Key Indicators</h2>
            <div class="kpi-grid">
                <div class="kpi-card">
                    <div class="kpi-label">Revenue</div>
                    <div class="kpi-value">RM 47.200,00</div>
                    <div class="kpi-sub"><span class="kpi-good">+12.1%</span> vs previous month</div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-label">Food Cost</div>
                    <div class="kpi-value kpi-warn">33.8%</div>
                    <div class="kpi-sub">COGS: RM 15.953,60</div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-label">Inventory</div>
                    <div class="kpi-value">RM 8400,00</div>
                    <div class="kpi-sub">4 Below minimum · 1 Out of stock</div>
                </div>
            </div>
        </section>

        <section>
            <h2>📝 Executive Summary</h2>
            <div class="resumen">Mes positivo con <strong>beneficio neto de 12.746 €</strong> (+12% vs mes anterior). Food cost dentro del rango objetivo.</div>
        </section>

        <section>
            <h2>💼 P&amp;L — Profit &amp; Loss</h2>
            
        <table class="pyg-table">
            <tr><td>Revenue</td><td class="num">RM 47.200,00</td></tr>
            <tr class="pyg-minus"><td>− COGS (cost of goods sold)</td><td class="num">RM 15.953,60</td></tr>
            <tr class="pyg-subtotal"><td>Gross margin</td><td class="num">RM 31.246,40</td></tr>
            <tr class="pyg-minus"><td>− Fixed costs <span class="pyg-sub-info">(8)</span></td><td class="num">RM 18.500,00</td></tr>
            <tr class="pyg-total"><td><strong>Net profit</strong></td><td class="num"><strong class="kpi-good">RM 12.746,40</strong></td></tr>
            <tr class="pyg-pct"><td>Net margin</td><td class="num"><span class="kpi-good">27.0%</span></td></tr>
        </table>
    
        </section>

        
        <section>
            <h2>📉 Daily revenue evolution</h2>
            <div class="sparkline-box">
    <svg viewBox="0 0 600 102" preserveAspectRatio="none" style="width:100%; height:110px;" role="img" aria-label="Evolución de ingresos">
        <defs>
            <linearGradient id="sl-area" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%"  stop-color="#1e3a8a" stop-opacity="0.35"/>
                <stop offset="100%" stop-color="#1e3a8a" stop-opacity="0"/>
            </linearGradient>
        </defs>
        <path d="M 8,72 L 8.0,27.8 L 154.0,16.5 L 300.0,20.5 L 446.0,8.0 L 592.0,12.6 L 592,72 Z" fill="url(#sl-area)" stroke="none"/>
        <polyline points="8.0,27.8 154.0,16.5 300.0,20.5 446.0,8.0 592.0,12.6" fill="none" stroke="#1e3a8a" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>
        <circle cx="446.0" cy="8.0" r="3.5" fill="#f59e0b" stroke="#fff" stroke-width="1.5"/>
        <text x="8" y="96" font-size="11" fill="#64748b" font-family="-apple-system, sans-serif">01 Apr</text>
        <text x="592" y="96" font-size="11" fill="#64748b" font-family="-apple-system, sans-serif" text-anchor="end">29 Apr</text>
        <text x="446.0" y="14.0" font-size="11" fill="#f59e0b" font-weight="700" font-family="-apple-system, sans-serif" text-anchor="middle">RM 2100,00</text>
    </svg></div>
        </section>
        

        
        <section>
            <h2>🔍 Observations</h2>
            <ul class="observaciones"><li>Ingresos crecen 12.1% vs marzo.</li><li>Pulpo subió 13.5% — revisar precio venta de Pulpo a la gallega.</li><li>Solomillo Wellington con food cost 48%, fuera de rango.</li></ul>
        </section>
        

        
        <section class="alertas">
            <h2>⚠️ Alerts</h2>
            
                <div class="alerta alerta-warning">Pulpo +13.5%: revisar margen.</div>
            
        </section>
    

        
        <section>
            <h2>💡 Recommendations</h2>
            
            <div class="reco">
                <div class="reco-title">Resubir precio de Pulpo a la gallega</div>
                <div class="reco-detalle">El plato bandera está a 71% de margen — buen colchón para repercutir +1€ sin perder volumen.</div>
